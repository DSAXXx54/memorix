{
  "memorix": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "memorix hook --agent antigravity --event PreInvocation",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent antigravity --event PreToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "memorix hook --agent antigravity --event PostToolUse",
            "timeout": 10
          }
        ]
      }
    ],
    "PostInvocation": [
      {
        "type": "command",
        "command": "memorix hook --agent antigravity --event PostInvocation",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "memorix hook --agent antigravity --event Stop",
        "timeout": 10
      }
    ]
  }
}

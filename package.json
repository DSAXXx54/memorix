{
  "name": "memorix",
  "version": "1.1.4",
  "description": "Local-first shared memory layer for AI coding agents across MCP clients, Git history, reasoning context, and project sessions.",
  "type": "module",
  "sideEffects": false,
  "workspaces": [
    "packages/ai",
    "packages/agent-core",
    "packages/tui",
    "packages/memcode"
  ],
  "bin": {
    "memorix": "./dist/cli/index.js",
    "memcode": "./dist/cli/memcode.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./sdk": {
      "import": "./dist/sdk.js",
      "types": "./dist/sdk.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.js",
    "!src/**/*.js.map",
    "!src/**/*.d.ts",
    "!src/**/*.d.ts.map",
    "README.md",
    "README.zh-CN.md",
    "assets",
    "docs",
    "!docs/memcode",
    "!docs/superpowers",
    "plugins",
    "TEAM.md",
    "LICENSE",
    "CHANGELOG.md",
    "CLAUDE.md",
    "llms.txt",
    "llms-full.txt"
  ],
  "scripts": {
    "build:workspaces": "npm --workspaces --if-present run build",
    "build": "npm run build:workspaces && node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run --no-file-parallelism --maxWorkers=1 --minWorkers=1",
    "test:watch": "vitest",
    "test:llm-live": "MEMORIX_RUN_LIVE_LLM_TESTS=1 vitest run tests/integration/formation-llm-quality.test.ts",
    "test:e2e": "vitest run tests/e2e/",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "cursor-mcp",
    "windsurf-mcp",
    "claude-code-memory",
    "codex-mcp",
    "copilot-mcp",
    "kiro-mcp",
    "antigravity-mcp",
    "openclaw-mcp",
    "hermes-agent",
    "oh-my-pi",
    "ai-coding-memory",
    "cross-ide-sync",
    "cross-agent-memory",
    "context-persistence",
    "agent-memory",
    "memcode",
    "coding-agent",
    "terminal-agent",
    "knowledge-graph",
    "workspace-sync",
    "progressive-disclosure",
    "session-memory",
    "vector-search",
    "rules-sync",
    "project-skills"
  ],
  "author": "AVIDS2",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AVIDS2/memorix.git"
  },
  "homepage": "https://github.com/AVIDS2/memorix#readme",
  "bugs": {
    "url": "https://github.com/AVIDS2/memorix/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/AVIDS2"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@orama/orama": "^3.1.0",
    "@orama/plugin-data-persistence": "^3.1.0",
    "citty": "^0.1.6",
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^2.5.0",
    "dagre": "^0.8.5",
    "diff": "^9.0.0",
    "dotenv": "^17.3.1",
    "gpt-tokenizer": "^2.8.0",
    "gray-matter": "^4.0.3",
    "ink": "^6.8.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-scroll-view": "^0.3.6",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^3.13.1",
    "react": "19.2.7",
    "remark": "^15.0.1",
    "remark-stringify": "^11.0.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "fastembed": "^1.14.4"
  },
  "overrides": {
    "tar": "^7.5.16",
    "react": "19.2.7",
    "@types/react": "19.2.7",
    "protobufjs": "^7.6.4",
    "lodash": "^4.18.1",
    "hono": "^4.12.26",
    "@hono/node-server": "^1.19.14",
    "express-rate-limit": "^8.5.2",
    "path-to-regexp": "^8.4.2",
    "ajv": "^8.20.0",
    "fast-uri": "^3.1.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "19.2.7",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "3.2.6"
  }
}

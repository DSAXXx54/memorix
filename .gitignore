# Dependencies & Build
node_modules/
dist/
*.tgz

# TypeScript build sidecars must never live next to source files.
# They shadow .ts modules when code imports ESM-style "./foo.js".
src/**/*.js
src/**/*.js.map
src/**/*.d.ts
src/**/*.d.ts.map
!src/dashboard/static/**/*.js
!src/embedding/fastembed.d.ts
!src/embedding/transformers.d.ts
!src/globals.d.ts
!src/types/memcode.d.ts

# Memorix data
.memorix-data/
*.backup-*

# Fastembed model cache (~133MB ONNX models)
local_cache/

# Dev-only files
demo/
image/
.tmp-*
*.tmp

# Test/demo artifacts
.pipeline/
.playwright-mcp/
.planning/
output/
memory-game-*.png

# Auto-generated agent configs
.agents/
.windsurfrules

# Logs & OS
*.log
.DS_Store
Thumbs.db

# Agent configs (auto-installed by memorix hooks)
.agent/
.claude/
.gemini/
.shared/
.codex/
.cursor/
.kiro/
.memorix/
.windsurf/hooks.json
.windsurf/rules/memorix.md
.github/copilot-instructions.md
AGENTS.md

# Test scripts
test-*.mjs
run-*.mjs
e2e-*.mts
e2e-*.mjs
e2e-test/
scripts/e2e-*.ts
scripts/tsconfig.json

# Reference / cloned repos
temple/

# memcode packages (built from source)
packages/*/dist/
packages/*/.tsbuildinfo

# CodeGraph
.codegraph/

# Session files
*.jsonl

